<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CiNemaPlus.Models"
             x:Class="CiNemaPlus.MainPage">
            <!--xmlns:viewmodel="clr-namespace:CiNemaPlus.ViewModels"-->
            <!--x:DataType="viewmodel:MovieViewModel"-->

    
            <!-- BANDEAU HORS DONNEES
            <Label Text="📴 Hors ligne — données locales"
            IsVisible="{Binding EstFallback}"
            BackgroundColor="#FFF3CD" TextColor="#856404"
            HorizontalTextAlignment="Center" Padding="8" />-->

            <CollectionView x:Name="MoviesCollection">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="5"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Movie">
                        <Label Text="{Binding Title}"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
</ContentPage>
