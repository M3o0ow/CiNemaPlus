<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CiNemaPlus.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="cinemaPlus"
             x:Class="CiNemaPlus.MainPage">

    <Shell.TitleView>
        <Label Text="Movies" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
    </Shell.TitleView>
    <RefreshView IsRefreshing="{Binding EstEnChargement}">
        <Grid RowDefinitions="Auto, Auto, *" Padding="20" RowSpacing="10">
        <!-- Bar de recherche-->
            <Border Grid.Row="0" BackgroundColor="#F1F3F4" StrokeShape="RoundRectangle 15" Padding="5">
            <SearchBar x:Name="SearchBar"
                Placeholder="Rechercher dans les articles..." 
                   BackgroundColor="#F1F3F4"
                   TextColor="Black"
                   TextChanged="OnSearchTextChanged">
            </SearchBar>
            </Border>

            <!-- BANDEAU HORS DONNEES-->
            <Label Grid.Row="1" Text="📴 Hors ligne — données locales"
                    IsVisible="{Binding EstFallback}"
                    BackgroundColor="#FFF3CD" TextColor="#856404"
                    HorizontalTextAlignment="Center" Padding="8" />

            <!-- Indicateur de chargement -->
            <ActivityIndicator Grid.Row="2" IsRunning="{Binding EstEnChargement}"
                IsVisible="{Binding EstEnChargement}"
                Color="#1E88E5"
                HorizontalOptions="Center" />
        
            <CollectionView x:Name="MoviesCollection"
                            ItemsSource="{Binding Movies}"
                            Grid.Row="3">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Movie">
                    <Grid RowDefinitions="35, 20, *" 
                          ColumnDefinitions="100, *" 
                          ColumnSpacing="10" 
                          Padding="5">
                        
                        <Border Grid.Column="0" Grid.RowSpan="4" StrokeShape="RoundRectangle 20 0 20 0"
                                StrokeThickness="0">
                            <Image 
                               Source="{Binding FullPosterUrl}" 
                               Aspect="AspectFill"/>
                        </Border>
                    
                        <Grid Grid.Column="1" Grid.Row="0" RowSpacing="2" VerticalOptions="Start" 
                              RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto, Auto">
                            <!-- Titre du film-->
                            <Label Grid.Row="0" Grid.Column="0"
                           Text="{Binding Title}" 
                           FontSize="14" 
                           FontAttributes="Bold" 
                           VerticalTextAlignment="Center"/>
                            
                            <!-- Langue -->
                            <HorizontalStackLayout Grid.Column="0" Grid.Row="1" Spacing="5" VerticalOptions="Center">
                                <Image Source="language.png" HeightRequest="14" WidthRequest="14">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="LightGrey" />
                                    </Image.Behaviors>
                                </Image>
                                <Label Text="{Binding Original_language}" FontSize="12"/>
                            </HorizontalStackLayout>
                            
                            <!-- Popularité -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                                <Image Source="people.png" HeightRequest="14" WidthRequest="14">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="LightGrey" />
                                    </Image.Behaviors>
                                </Image>
                                <Label Text="{Binding Popularity, StringFormat='{0:F0}'}" FontSize="12"/>
                            </HorizontalStackLayout>
                            
                            <!-- Note -->
                            <HorizontalStackLayout Grid.Column="1" Grid.Row="2" Spacing="2" VerticalOptions="Center">
                                <Image Source="star.png" HeightRequest="14" WidthRequest="14">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="Orange" />
                                    </Image.Behaviors>
                                </Image>
                                <Label Text="{Binding Vote_average, StringFormat='{0:F1}'}" FontSize="12"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <HorizontalStackLayout Grid.Column="1" Grid.Row="2" Spacing="5" VerticalOptions="End">
                            <Image Source="calendar.png" HeightRequest="14" WidthRequest="14">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="LightGrey" />
                                </Image.Behaviors>
                            </Image>
                            <Label Text="{Binding Release_date, StringFormat='{0:F1}'}" FontSize="12"/>
                        </HorizontalStackLayout>
                    </Grid>
                </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

    </Grid>
    </RefreshView>
</ContentPage>
